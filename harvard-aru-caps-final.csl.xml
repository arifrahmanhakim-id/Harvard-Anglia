<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="in-text" version="1.0">
  <info>
    <title>Harvard Anglia Ruskin (CAPS Bibliography Only)</title>
    <id>http://custom/harvard-aru-caps</id>
  </info>

  <!-- SITASI DALAM TEKS (NORMAL) -->
  <citation>
    <layout prefix="(" suffix=")" delimiter="; ">
      <group delimiter=", ">
        <names variable="author">
          <name form="short"/>
        </names>
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </group>
    </layout>
  </citation>

  <!-- DAFTAR PUSTAKA (CAPITAL AUTHOR) -->
  <bibliography>
    <sort>
      <key variable="author"/>
      <key variable="issued"/>
    </sort>

    <layout suffix=".">
      <group delimiter=" ">
        
        <!-- AUTHOR CAPS -->
        <names variable="author">
          <name name-as-sort-order="all"
                initialize-with="."
                delimiter=", "
                and="text"
                text-case="uppercase"/>
        </names>

        <!-- YEAR -->
        <date variable="issued">
          <date-part name="year" prefix="(" suffix=")"/>
        </date>

      </group>

      <!-- TITLE -->
      <text variable="title" prefix=" "/>

      <!-- JOURNAL / BOOK -->
      <group prefix=". ">
        <text variable="container-title" font-style="italic"/>
      </group>

      <!-- VOLUME / ISSUE -->
      <group prefix=", ">
        <text variable="volume"/>
        <text variable="issue" prefix="(" suffix=")"/>
      </group>

      <!-- PAGE -->
      <group prefix=", ">
        <text variable="page"/>
      </group>

      <!-- DOI -->
      <text variable="DOI" prefix=". https://doi.org/"/>

    </layout>
  </bibliography>
</style>